{
  "name": "openclaw-guard",
  "version": "2.0.0",
  "description": "OpenClaw 管理工具 - 服务管理、渠道配置、AI模型、安全审计",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openclaw-guard": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts web --port 18088",
    "dev:cli": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "web": "tsx src/index.ts web --port 18088"
  },
  "keywords": [
    "openclaw",
