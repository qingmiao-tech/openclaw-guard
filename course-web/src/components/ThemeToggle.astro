---
---

<button
  id="theme-toggle"
  class="p-2 rounded-lg hover:bg-surface-alt dark:hover:bg-surface-dark-alt transition-colors"
  aria-label="切换暗色模式"
  title="切换暗色模式"
>
  <svg id="sun-icon" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <svg id="moon-icon" class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
</button>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    try {
      const raw = localStorage.getItem('openclaw-course-progress');
      const data = raw ? JSON.parse(raw) : { chapters: {}, lastVisited: '', darkMode: false };
      data.darkMode = isDark;
      localStorage.setItem('openclaw-course-progress', JSON.stringify(data));
    } catch(e) {}
  });
</script>
