{
  "name": "openclaw-guard",
  "version": "0.9.0",
  "description": "Native OpenClaw operations and security toolkit with security presets, agent Markdown asset management, and deep Git sync.",
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/qingmiao-tech/openclaw-guard.git"
  },
  "homepage": "https://github.com/qingmiao-tech/openclaw-guard",
  "bugs": {
    "url": "https://github.com/qingmiao-tech/openclaw-guard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "openclaw-guard": "dist/index.js"
  },
  "files": [
    "dist",
    "web",
    "launchers",
    "scripts/restart-web.mjs",
    "scripts/status-web.mjs",
    "scripts/stop-web.mjs",
    "scripts/web-background.mjs",
    "install.sh",
    "install.ps1",
    "README.md",
    "README.en.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "clean:dist": "node scripts/clean-dist.mjs",
    "build": "npm run clean:dist && tsc",
    "dev": "node scripts/dev-runner.mjs",
    "dev:tsx": "tsx src/index.ts web --port 18088",
    "dev:dist": "npm run build && node dist/index.js web --port 18088",
    "dev:cli": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run",
    "web": "tsx src/index.ts web --port 18088",
    "web:bg:start": "npm run build && node scripts/web-background.mjs start --port 18088",
    "web:bg:stop": "node scripts/web-background.mjs stop --port 18088",
    "web:bg:status": "node scripts/web-background.mjs status --port 18088",
    "ui:smoke": "python scripts/guard-ui-smoke.py",
    "ui:smoke:interactions": "python scripts/guard-ui-interactions.py",
    "ui:smoke:with-web": "node scripts/run-ui-smoke.mjs",
    "web:bg:restart": "node scripts/restart-web.mjs",
    "web:bg:down": "node scripts/stop-web.mjs",
    "web:bg:show-status": "node scripts/status-web.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "openclaw",
    "security",
    "permissions",
    "guard",
    "config"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "fast-check": "^4.5.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.3"
  }
}
