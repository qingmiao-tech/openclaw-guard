---
import type { TocItem } from '../types';

interface Props {
  items: TocItem[];
}

const { items } = Astro.props;
---

{items.length > 0 && (
  <nav class="toc hidden xl:block fixed right-4 top-20 w-56 max-h-[calc(100vh-6rem)] overflow-y-auto text-sm">
    <h4 class="font-semibold text-text-muted dark:text-text-dark-muted mb-2 text-xs uppercase tracking-wider">本章目录</h4>
    <ul class="space-y-1 border-l-2 border-border dark:border-border-dark pl-3">
      {items.map((item) => (
        <li>
          <a
            href={`#${item.slug}`}
            class="block py-0.5 text-text-muted dark:text-text-dark-muted hover:text-primary dark:hover:text-primary-light transition-colors text-xs leading-relaxed"
          >
            {item.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
