---
---

<div class="search-container relative">
  <div class="relative">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted dark:text-text-dark-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <input
      id="search-input"
      type="text"
      placeholder="搜索课程内容..."
      class="w-full pl-10 pr-4 py-2 text-sm rounded-lg border border-border dark:border-border-dark bg-surface dark:bg-surface-dark-alt text-text dark:text-text-dark placeholder-text-muted dark:placeholder-text-dark-muted focus:outline-none focus:ring-2 focus:ring-primary/50"
    />
  </div>
  <div id="search-results" class="absolute top-full left-0 right-0 mt-1 bg-surface dark:bg-surface-dark border border-border dark:border-border-dark rounded-lg shadow-lg max-h-80 overflow-y-auto z-50 hidden">
  </div>
</div>

<script is:inline>
  let searchIndex = null;
  let fuse = null;

  async function initSearch() {
    if (searchIndex) return;
    try {
      const res = await fetch('/search-index.json');
      searchIndex = await res.json();
      const Fuse = (await import('https://cdn.jsdelivr.net/npm/fuse.js@7.1.0/dist/fuse.mjs')).default;
      fuse = new Fuse(searchIndex, {
        keys: ['chapterTitle', 'slideTitle', 'content'],
        threshold: 0.3,
        includeMatches: true,
        minMatchCharLength: 2,
      });
    } catch(e) {
      console.warn('Search index not available');
    }
  }

  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');

  searchInput?.addEventListener('focus', initSearch);
  searchInput?.addEventListener('input', (e) => {
    const query = e.target.value.trim();
    if (!query || !fuse) {
      searchResults.classList.add('hidden');
      searchResults.innerHTML = '';
      return;
    }

    const results = fuse.search(query, { limit: 10 });
    if (results.length === 0) {
      searchResults.innerHTML = '<div class="p-4 text-sm text-text-muted dark:text-text-dark-muted text-center">未找到匹配结果</div>';
      searchResults.classList.remove('hidden');
      return;
    }

    searchResults.innerHTML = results.map(r => {
      const item = r.item;
      const snippet = item.content.substring(0, 100) + '...';
      return `<a href="/${item.chapterId}#${item.slug}" class="block px-4 py-3 hover:bg-surface-alt dark:hover:bg-surface-dark-alt border-b border-border dark:border-border-dark last:border-0 transition-colors">
        <div class="text-xs text-text-muted dark:text-text-dark-muted">${item.chapterTitle}</div>
        <div class="text-sm font-medium text-text dark:text-text-dark">${item.slideTitle}</div>
        <div class="text-xs text-text-muted dark:text-text-dark-muted mt-1 line-clamp-2">${snippet}</div>
      </a>`;
    }).join('');
    searchResults.classList.remove('hidden');
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.search-container')) {
      searchResults?.classList.add('hidden');
    }
  });
</script>
