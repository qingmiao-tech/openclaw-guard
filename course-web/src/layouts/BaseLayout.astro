---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'OpenClaw 实战训练营 - 交互式网页版' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | OpenClaw 实战训练营</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen">
    <slot />
    <script is:inline>
      // Restore dark mode preference before paint
      (function() {
        try {
          const stored = localStorage.getItem('openclaw-course-progress');
          if (stored) {
            const data = JSON.parse(stored);
            if (data.darkMode) {
              document.documentElement.classList.add('dark');
            }
          }
        } catch(e) {}
      })();
    </script>
  </body>
</html>
