    "commander": "^12.1.0",
    "inquirer": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "fast-check": "^4.5.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.3"
  }
}
