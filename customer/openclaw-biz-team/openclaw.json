{
  "models": {
    "mode": "merge",
    "providers": {
      "openai-codex": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "models": [
          {
            "id": "gpt-5.3-codex",
            "name": "GPT-5.3 Codex",
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      },
      "qwen-portal": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "${DASHSCOPE_API_KEY}",
        "models": [
          {
            "id": "qwen3.5-plus",
            "name": "Qwen 3.5 Plus",
            "contextWindow": 32000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "task-hub",
        "market-research",
        "data-analysis",
        "ad-ops",
        "logistics-customs",
        "finance-manager",
        "copy-editor"
      ]
    },
    "sessions": {
      "visibility": "all"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/customer-biz-team/workspaces/task-hub",
      "model": {
        "primary": "openai-codex/gpt-5.3-codex",
        "fallbacks": [
          "qwen-portal/qwen3.5-plus"
        ]
      },
      "models": {
        "openai-codex/gpt-5.3-codex": {
          "alias": "primary"
        },
        "qwen-portal/qwen3.5-plus": {
          "alias": "backup-cn"
        }
      },
      "timeoutSeconds": 600
    },
    "list": [
      {
        "id": "task-hub",
        "default": true,
        "name": "任务分发记忆中枢",
        "workspace": "~/.openclaw/customer-biz-team/workspaces/task-hub",
        "subagents": {
          "allowAgents": [
            "*"
          ]
        }
      },
      {
        "id": "market-research",
        "name": "市场调研",
        "workspace": "~/.openclaw/customer-biz-team/workspaces/market-research"
      },
      {
        "id": "data-analysis",
        "name": "数据分析",
        "workspace": "~/.openclaw/customer-biz-team/workspaces/data-analysis"
      },
      {
        "id": "ad-ops",
        "name": "广告运营",
        "workspace": "~/.openclaw/customer-biz-team/workspaces/ad-ops"
      },
      {
        "id": "logistics-customs",
        "name": "物流报关",
        "workspace": "~/.openclaw/customer-biz-team/workspaces/logistics-customs"
      },
      {
        "id": "finance-manager",
        "name": "财务主管",
        "workspace": "~/.openclaw/customer-biz-team/workspaces/finance-manager"
      },
      {
        "id": "copy-editor",
        "name": "文案编辑",
        "workspace": "~/.openclaw/customer-biz-team/workspaces/copy-editor"
      }
    ]
  }
}
